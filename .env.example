# Device: "cpu" or "cuda" (auto-detected by run.sh)
# VOICEBOX_DEVICE=cpu

# Exposed port (default: 17493)
# VOICEBOX_PORT=17493

# TTS model to auto-download on first run (set empty to skip)
# VOICEBOX_TTS_MODEL=qwen-tts-1.7B

# STT model to auto-download on first run (set empty to skip)
# VOICEBOX_STT_MODEL=whisper-turbo

# Enable flash-attn compilation (CUDA only, adds ~15-20 min to first build)
# FLASH_ATTN=0

# Data directory: local path or Docker volume name (default: Docker named volume)
# VOICEBOX_DATA=./data
